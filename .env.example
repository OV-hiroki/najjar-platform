# ─── Database ─────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/elgohary_db"

# ─── NextAuth ─────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET="CHANGE_ME_min32chars_openssl_rand_base64_32"
NEXTAUTH_URL="https://yourdomain.com"  # use http://localhost:3000 in dev

# ─── JWT ──────────────────────────────────────────────
JWT_SECRET="CHANGE_ME_another_random_secret_min32"

# ─── Video signed URLs ────────────────────────────────
# Generate: openssl rand -base64 32
VIDEO_SIGN_SECRET="CHANGE_ME_video_secret_min32chars"

# ─── Fawry Payment ────────────────────────────────────
FAWRY_MERCHANT_CODE="your-fawry-merchant-code"
FAWRY_SECURITY_KEY="your-fawry-security-key"
# Staging (for testing):
FAWRY_API_URL="https://atfawry.fawrystaging.com/ECommerceWeb/Fawry/payments"
# Production:
# FAWRY_API_URL="https://www.atfawry.com/ECommerceWeb/Fawry/payments"

# ─── Cloudinary (images) ──────────────────────────────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ─── App Config ───────────────────────────────────────
NEXT_PUBLIC_APP_NAME="الجوهري"
NEXT_PUBLIC_APP_URL="https://yourdomain.com"
NEXT_PUBLIC_COUNTDOWN_TARGET="2026-07-17T00:00:00"

# ─── Center code ──────────────────────────────────────
CENTER_CODE_PREFIX="GHR"

# ─── Security ─────────────────────────────────────────
NODE_ENV="production"
# NEVER expose these to client — no NEXT_PUBLIC_ prefix on secrets
